# ══════════════════════════════════════════════════════════════════
# ÁLBUM ESTRELLAS — Variables de entorno
# Copia este archivo como .env y llena cada valor
# NUNCA subas el archivo .env a GitHub
# ══════════════════════════════════════════════════════════════════

# ── SUPABASE ──────────────────────────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...    # Service Role Key (NO la anon key)

# ── GOOGLE SHEETS ─────────────────────────────────────────────────
# ID del Google Sheet (está en la URL: /spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Ruta al archivo JSON de credenciales de la cuenta de servicio de Google
GOOGLE_SERVICE_ACCOUNT_FILE=./google-credentials.json

# Nombre de la hoja (pestaña) dentro del Google Sheet
GOOGLE_SHEET_TAB=Ventas

# ── JWT ───────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens de sesión (mínimo 32 caracteres)
JWT_SECRET=cambia-esto-por-una-clave-muy-larga-y-segura-2026

# ── SERVIDOR ──────────────────────────────────────────────────────
PORT=3000

# URL del frontend (para CORS)
FRONTEND_URL=https://tu-album.vercel.app
